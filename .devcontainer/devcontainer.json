{
  "name": "corecast-jazzy",
  "image": "corecast/dev:jazzy-24.04",
  "initializeCommand": "earthly +devcontainer-image",
  "updateRemoteUserUID": true,
  "runArgs": [
    "--gpus=all"
  ],
  "workspaceFolder": "/workspaces/CoreCast",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/CoreCast,type=bind",
  "postCreateCommand": "echo \"alias build='(cd /workspaces/CoreCast && cmake -G Ninja -S corecast_optix -B build/corecast_optix -DOPTIX_SDK_PATH=/workspaces/CoreCast/third_party/NVIDIA-OptiX-SDK-9.0.0-linux64-x86_64 -DCMAKE_BUILD_TYPE=Release && cmake --build build/corecast_optix -j)'\" >> ~/.bashrc",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "ms-python.python",
        "ms-iot.vscode-ros"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",
        "editor.formatOnSave": true,
        "[c]": {
          "editor.defaultFormatter": "ms-vscode.cpptools"
        },
        "[cpp]": {
          "editor.defaultFormatter": "ms-vscode.cpptools"
        },
        "C_Cpp.formatting": "clangFormat",
        "C_Cpp.clang_format_style": "file"
      }
    }
  }
}
